# Supabase Configuration
# The URL of your Supabase project (found in Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=

# The Anon/Public key for your Supabase project (found in Project Settings -> API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Site URL (used for password reset redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Vercel OIDC Token or Cloudflare Workers environment variables can be added here
# VERCEL_OIDC_TOKEN=
